<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Admin Dashboard - <%= siteName || 'ExHub' %></title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  
  <!-- SCRIPT PENCEGAH FOUC (Flash of Unstyled Content) -->
  <script>
    (function() {
      const savedRgb = localStorage.getItem('exhub_theme_rgb');
      if (savedRgb) {
        document.documentElement.style.setProperty('--accent-rgb', savedRgb);
      }
    })();
  </script>

  <link rel="stylesheet" href="/public/css/main.css" />
  <link rel="icon" type="image/png" href="/public/img/logo-exhub.png" />
  <script src="/public/js/protect.js" defer></script>

  <!-- =========================================
       ANIMASI KELAS DEWA (Fade In, Slide, Zoom)
       ========================================= -->
  <style>
    @keyframes fadeInUp {
      0% { opacity: 0; transform: translateY(40px); }
      100% { opacity: 1; transform: translateY(0); }
    }
    @keyframes fadeInLeft {
      0% { opacity: 0; transform: translateX(-40px); }
      100% { opacity: 1; transform: translateX(0); }
    }
    @keyframes fadeInRight {
      0% { opacity: 0; transform: translateX(40px); }
      100% { opacity: 1; transform: translateX(0); }
    }
    @keyframes zoomIn {
      0% { opacity: 0; transform: scale(0.9); }
      100% { opacity: 1; transform: scale(1); }
    }

    .animate-up { opacity: 0; animation: fadeInUp 0.8s cubic-bezier(0.165, 0.84, 0.44, 1) forwards; }
    .animate-left { opacity: 0; animation: fadeInLeft 0.8s cubic-bezier(0.165, 0.84, 0.44, 1) forwards; }
    .animate-right { opacity: 0; animation: fadeInRight 0.8s cubic-bezier(0.165, 0.84, 0.44, 1) forwards; }
    .animate-zoom { opacity: 0; animation: zoomIn 0.6s cubic-bezier(0.165, 0.84, 0.44, 1) forwards; }

    /* Static delays untuk elemen tertentu */
    .delay-1 { animation-delay: 0.1s; }
    .delay-2 { animation-delay: 0.2s; }
    .delay-3 { animation-delay: 0.3s; }
    .delay-4 { animation-delay: 0.4s; }
    .delay-5 { animation-delay: 0.5s; }
  </style>
</head>
<body class="page-dark">
  <%- include('partials/nav', { active: 'admin' }) %>

  <main class="container">

    <!-- Page Header -->
    <section class="page-header">
      <!-- Judul muncul dari kiri -->
      <div class="page-header-main animate-left delay-1">
        <div>
          <h1>Admin Dashboard</h1>
          <p>
            Only Discord IDs in <code>ADMIN_DISCORD_IDS</code> atau kredensial
            <code>ADMIN_USER / ADMIN_PASS</code> yang valid bisa mengakses halaman ini.
          </p>
        </div>
      </div>

      <!-- Info login muncul dari kanan -->
      <div class="admin-info-bar animate-right delay-2">
        <div>
          <span class="admin-label">Logged in as:</span>
          <span class="admin-name"><%= user && user.username ? user.username : 'Admin' %></span>
        </div>
        <form action="/admin/logout" method="post">
          <button type="submit" class="btn btn-outline btn-sm">Logout</button>
        </form>
      </div>
    </section>

    <!-- Alert / flash message dari cleanupSummary -->
    <% if (cleanupSummary) { %>
      <section class="alert <%= cleanupSummary.type === 'error' ? 'alert-error' : 'alert-success' %> animate-up delay-2">
        <div class="alert-title">
          <%= cleanupSummary.type === 'error' ? 'Action Failed' : 'Action Succeeded' %>
        </div>
        <p><%= cleanupSummary.message %></p>
      </section>
    <% } %>

    <!-- Key Stats Summary -->
    <% if (keyStats && keyStats.summary) { %>
      <section class="card animate-up delay-3">
        <h2>Key Statistics</h2>
        <p class="helper-text">
          Statistik global untuk semua user dan key yang terdata di Redis / KV.
        </p>

        <!-- Stats Grid dengan delay zoom-in yang berurutan -->
        <div class="stats-grid">
          <div class="stat-card animate-zoom" style="animation-delay: 0.3s;">
            <div class="stat-label">Total Users</div>
            <div class="stat-value"><%= keyStats.summary.totalUsers || 0 %></div>
          </div>
          <div class="stat-card animate-zoom" style="animation-delay: 0.4s;">
            <div class="stat-label">Total Keys</div>
            <div class="stat-value"><%= keyStats.summary.totalKeys || 0 %></div>
          </div>
          <div class="stat-card animate-zoom" style="animation-delay: 0.5s;">
            <div class="stat-label">Active Keys</div>
            <div class="stat-value stat-value-success"><%= keyStats.summary.activeKeys || 0 %></div>
          </div>
          <div class="stat-card animate-zoom" style="animation-delay: 0.6s;">
            <div class="stat-label">Expired Keys</div>
            <div class="stat-value stat-value-warning"><%= keyStats.summary.expiredKeys || 0 %></div>
          </div>
          <div class="stat-card animate-zoom" style="animation-delay: 0.7s;">
            <div class="stat-label">Deleted Keys</div>
            <div class="stat-value stat-value-danger"><%= keyStats.summary.deletedKeys || 0 %></div>
          </div>
          <div class="stat-card animate-zoom" style="animation-delay: 0.8s;">
            <div class="stat-label">Orphan Tokens</div>
            <div class="stat-value stat-value-muted"><%= keyStats.summary.orphanTokens || 0 %></div>
          </div>
        </div>
      </section>
    <% } else { %>
      <section class="card animate-up delay-3">
        <h2>Key Statistics</h2>
        <p class="helper-text">
          Tidak dapat memuat statistik key. Cek koneksi Redis / KV atau log server.
        </p>
      </section>
    <% } %>

    <!-- Admin Actions -->
    <section class="card animate-up delay-4">
      <h2>Admin Actions</h2>
      <p class="helper-text">
        Aksi cepat untuk maintenance key & user. Beberapa aksi bersifat permanen, gunakan dengan hati-hati.
      </p>

      <div class="admin-actions-grid">

        <% 
          // Hitung TTL current & default (jam) untuk ditampilkan & dipakai di form
          var ttlHoursDisplay = 3;
          var defaultTtlHoursDisplay = 3;

          if (keyConfig) {
            if (typeof keyConfig.ttlHours === 'number') {
              ttlHoursDisplay = keyConfig.ttlHours;
            } else if (keyConfig.ttlHours) {
              var _n = Number(keyConfig.ttlHours);
              if (!isNaN(_n) && _n > 0) ttlHoursDisplay = _n;
            }

            if (typeof keyConfig.defaultTtlHours === 'number') {
              defaultTtlHoursDisplay = keyConfig.defaultTtlHours;
            } else if (keyConfig.defaultTtlHours) {
              var _d = Number(keyConfig.defaultTtlHours);
              if (!isNaN(_d) && _d > 0) defaultTtlHoursDisplay = _d;
            }
          }
        %>

        <!-- Key TTL Config (Get New Key) -->
        <!-- Kartu aksi muncul bertahap -->
        <div class="admin-action-card animate-up" style="animation-delay: 0.4s;">
          <h3>Key TTL (Get New Key)</h3>
          <p>
            Mengatur durasi berlaku key yang dihasilkan dari halaman
            <code>/get-key</code>. Perubahan disimpan di Redis dan berlaku realtime
            untuk semua instance (tanpa redeploy). Durasi ini juga ditampilkan
            di UI "Get New Key".
          </p>

          <div class="ttl-info">
            <p class="helper-text">
              <strong>Current TTL:</strong>
              <span><%= ttlHoursDisplay %> jam</span>
            </p>
            <p class="helper-text">
              <strong>Default TTL (fallback):</strong>
              <span><%= defaultTtlHoursDisplay %> jam</span>
            </p>
          </div>

          <form action="/admin/update-key-ttl" method="post" class="form-inline">
            <input
              type="number"
              step="0.1"
              min="0.1"
              name="ttlHours"
              class="input"
              value="<%= ttlHoursDisplay %>"
              placeholder="Durasi key dalam jam (misal: 3, 6, 12)"
              required
            />
            <button
              type="submit"
              class="btn btn-primary"
              onclick="return confirm('Update durasi key menjadi ' + this.form.ttlHours.value + ' jam? Semua key baru akan menggunakan TTL ini.');"
            >
              Update Key TTL
            </button>
          </form>

          <p class="helper-text">
            Catatan: perubahan ini <strong>tidak mengubah</strong> key yang sudah
            dibuat sebelumnya, tapi semua <strong>key baru</strong> akan memakai durasi baru.
          </p>
        </div>

        <!-- Cleanup All Expired / Deleted / Orphan Keys -->
        <div class="admin-action-card animate-up" style="animation-delay: 0.5s;">
          <h3>Cleanup Keys</h3>
          <p>
            Menghapus token yang sudah expired / deleted / orphan dari list
            <code>user:*:keys</code> dan menghapus doc <code>key:token</code> yang tidak diperlukan.
          </p>
          <form action="/admin/cleanup-keys" method="post">
            <button
              type="submit"
              class="btn btn-primary"
              onclick="return confirm('Jalankan cleanup semua key expired/deleted/orphan?');"
            >
              Run Cleanup Keys
            </button>
          </form>
        </div>

        <!-- Cleanup Users -->
        <div class="admin-action-card animate-up" style="animation-delay: 0.6s;">
          <h3>Cleanup Users</h3>
          <p>
            Menghapus entry <code>user:*:keys</code> untuk user yang <strong>tidak punya key aktif sama sekali</strong>.
            Key yang sudah expired / deleted tetap dihapus dari list user.
          </p>
          <form action="/admin/cleanup-users" method="post">
            <button
              type="submit"
              class="btn btn-outline"
              onclick="return confirm('Hapus semua user list yang tidak punya key aktif?');"
            >
              Run Cleanup Users
            </button>
          </form>
        </div>

        <!-- Delete all keys for a given user -->
        <div class="admin-action-card animate-up" style="animation-delay: 0.7s;">
          <h3>Delete All Keys for User</h3>
          <p>
            Hapus semua key untuk satu user (berdasarkan Discord <code>userId</code>).
            Termasuk list <code>user:userId:keys</code> dan semua doc <code>key:token</code>-nya.
          </p>
          <form action="/admin/delete-user-keys" method="post" class="form-inline">
            <input
              type="text"
              name="userId"
              class="input"
              placeholder="Discord userId (contoh: 1188338848523xxxx)"
              required
            />
            <button
              type="submit"
              class="btn btn-danger"
              onclick="return confirm('Yakin hapus SEMUA key untuk user ini?');"
            >
              Delete User Keys
            </button>
          </form>
        </div>

        <!-- Delete single key -->
        <div class="admin-action-card animate-up" style="animation-delay: 0.8s;">
          <h3>Delete Single Key</h3>
          <p>
            Hapus satu key tertentu di semua tempat (doc <code>key:token</code> dan dari list user).
          </p>
          <form action="/admin/delete-key" method="post" class="form-inline">
            <input
              type="text"
              name="token"
              class="input"
              placeholder="EXHUBFREE-XXXXYYYY-XXXX-XXXX"
              required
            />
            <button
              type="submit"
              class="btn btn-danger"
              onclick="return confirm('Yakin hapus key ini?');"
            >
              Delete Key
            </button>
          </form>
        </div>

      </div>
    </section>

    <!-- Users & Keys Management -->
    <section class="card animate-up delay-5">
      <h2>Users & Keys Management</h2>
      <p class="helper-text">
        Daftar user yang memiliki key. Setiap user menampilkan ringkasan key dan detail token.
      </p>

      <% if (keyStats && keyStats.users && keyStats.users.length > 0) { %>
        <div class="users-list">
          <!-- Loop dengan penambahan index untuk delay animasi per user-card -->
          <% keyStats.users.forEach(function(u, index) { %>
            <div class="user-card animate-up" style="animation-delay: <%= (index * 0.1) + 0.5 %>s;">
              <div class="user-card-header">
                <div>
                  <div class="user-id">
                    User ID:
                    <code><%= u.userId %></code>
                  </div>
                  <div class="user-stats">
                    <span class="badge badge-muted">
                      Total: <strong><%= u.totalKeys %></strong>
                    </span>
                    <span class="badge badge-success">
                      Active: <strong><%= u.activeKeys %></strong>
                    </span>
                    <span class="badge badge-warning">
                      Expired: <strong><%= u.expiredKeys %></strong>
                    </span>
                    <span class="badge badge-danger">
                      Deleted: <strong><%= u.deletedKeys %></strong>
                    </span>
                    <span class="badge badge-outline">
                      Orphan: <strong><%= u.orphanTokens %></strong>
                    </span>
                  </div>
                </div>
                <div>
                  <form action="/admin/delete-user-keys" method="post">
                    <input type="hidden" name="userId" value="<%= u.userId %>" />
                    <button
                      type="submit"
                      class="btn btn-danger btn-sm"
                      onclick="return confirm('Hapus semua key untuk user <%= u.userId %>?');"
                    >
                      Delete All Keys for This User
                    </button>
                  </form>
                </div>
              </div>

              <% if (u.tokens && u.tokens.length > 0) { %>
                <div class="table-wrapper">
                  <table class="keys-table">
                    <thead>
                      <tr>
                        <th>Token</th>
                        <th>Status</th>
                        <th>Provider</th>
                        <th>IP</th>
                        <th>Created At</th>
                        <th>Expires At</th>
                        <th>Actions</th>
                      </tr>
                    </thead>
                    <tbody>
                      <% u.tokens.forEach(function(t) { %>
                        <%
                          var statusClass = '';
                          var statusText = '';

                          if (t.missing) {
                            statusClass = 'badge-muted';
                            statusText = 'Missing (doc expired)';
                          } else if (t.deleted) {
                            statusClass = 'badge-danger';
                            statusText = 'Deleted';
                          } else if (t.expired) {
                            statusClass = 'badge-warning';
                            statusText = 'Expired';
                          } else if (t.active) {
                            statusClass = 'badge-success';
                            statusText = 'Active';
                          } else {
                            statusClass = 'badge-outline';
                            statusText = 'Unknown';
                          }

                          var createdAt = t.info && t.info.createdAt
                            ? new Date(t.info.createdAt).toLocaleString()
                            : '-';

                          var expiresAt = t.info && t.info.expiresAfter
                            ? new Date(t.info.expiresAfter).toLocaleString()
                            : '-';

                          var provider = t.info && t.info.provider
                            ? t.info.provider
                            : '-';

                          var ip = t.info && t.info.byIp
                            ? t.info.byIp
                            : '-';
                        %>
                        <tr>
                          <td><code><%= t.token %></code></td>
                          <td>
                            <span class="badge <%= statusClass %>">
                              <%= statusText %>
                            </span>
                          </td>
                          <td><%= provider %></td>
                          <td><%= ip %></td>
                          <td><%= createdAt %></td>
                          <td><%= expiresAt %></td>
                          <td>
                            <form action="/admin/delete-key" method="post">
                              <input type="hidden" name="token" value="<%= t.token %>" />
                              <button
                                type="submit"
                                class="btn btn-outline btn-sm"
                                onclick="return confirm('Hapus key <%= t.token %>?');"
                              >
                                Delete
                              </button>
                            </form>
                          </td>
                        </tr>
                      <% }) %>
                    </tbody>
                  </table>
                </div>
              <% } else { %>
                <p class="helper-text">User ini tidak memiliki token yang tersisa.</p>
              <% } %>
            </div>
          <% }) %>
        </div>
      <% } else { %>
        <p class="helper-text">
          Belum ada user yang menyimpan key, atau gagal memuat data dari Redis.
        </p>
      <% } %>
    </section>

    <!-- Scripts Config (read-only) -->
    <section class="card animate-up delay-5">
      <h2>Scripts Config (read-only)</h2>
      <p class="helper-text">
        Tabel ini dibaca dari <code>config/loader.json</code>. Jika ingin, kamu bisa
        extend halaman ini untuk menyimpan perubahan ke Redis agar update tanpa redeploy.
      </p>

      <div class="table-wrapper">
        <table class="keys-table">
          <thead>
            <tr>
              <th>ID</th>
              <th>Name</th>
              <th>Version</th>
              <th>Status</th>
              <th>Game URL</th>
            </tr>
          </thead>
          <tbody>
            <% (scripts || []).forEach(function(s, index) { %>
              <tr class="animate-up" style="animation-delay: <%= (index * 0.1) + 0.6 %>s;">
                <td><code><%= s.id %></code></td>
                <td><%= s.name %></td>
                <td><%= s.version %></td>
                <td><%= s.status %></td>
                <td>
                  <% if (s.gameUrl) { %>
                    <a href="<%= s.gameUrl %>" target="_blank" rel="noopener noreferrer">open</a>
                  <% } else { %>
                    <span class="helper-text">-</span>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </section>
  </main>

  <!-- =========================================
       TOMBOL WIDGET: THEME SWITCHER (20 WARNA)
       ========================================= -->
  <div class="theme-switcher-wrapper">
    <button class="theme-toggle-btn" id="theme-toggle" aria-label="Toggle Theme Panel">
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="3"></circle>
        <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path>
      </svg>
    </button>
    <div class="theme-panel" id="theme-panel">
      <h4>Accent Color</h4>
      <div class="theme-colors">
        <!-- Baris 1: Hijau & Biru Terang -->
        <button class="color-btn active" style="background: rgb(125, 252, 69); color: rgb(125, 252, 69);" data-color="125, 252, 69" data-theme="green" title="Neon Green"></button>
        <button class="color-btn" style="background: rgb(57, 255, 20); color: rgb(57, 255, 20);" data-color="57, 255, 20" data-theme="toxic" title="Toxic Green"></button>
        <button class="color-btn" style="background: rgb(0, 255, 170); color: rgb(0, 255, 170);" data-color="0, 255, 170" data-theme="mint" title="Aqua Mint"></button>
        <button class="color-btn" style="background: rgb(0, 238, 255); color: rgb(0, 238, 255);" data-color="0, 238, 255" data-theme="electric" title="Electric Blue"></button>
        <button class="color-btn" style="background: rgb(69, 182, 252); color: rgb(69, 182, 252);" data-color="69, 182, 252" data-theme="cyan" title="Cyan Blue"></button>

        <!-- Baris 2: Biru, Ungu & Nila -->
        <button class="color-btn" style="background: rgb(153, 221, 255); color: rgb(153, 221, 255);" data-color="153, 221, 255" data-theme="ice" title="Ice Blue"></button>
        <button class="color-btn" style="background: rgb(138, 43, 226); color: rgb(138, 43, 226);" data-color="138, 43, 226" data-theme="violet" title="Deep Violet"></button>
        <button class="color-btn" style="background: rgb(182, 69, 252); color: rgb(182, 69, 252);" data-color="182, 69, 252" data-theme="purple" title="Synthwave Purple"></button>
        <button class="color-btn" style="background: rgb(75, 0, 130); color: rgb(75, 0, 130);" data-color="75, 0, 130" data-theme="indigo" title="Abyssal Indigo"></button>
        <button class="color-btn" style="background: rgb(255, 0, 255); color: rgb(255, 0, 255);" data-color="255, 0, 255" data-theme="plasma" title="Plasma Pink"></button>

        <!-- Baris 3: Merah Muda, Merah & Koral -->
        <button class="color-btn" style="background: rgb(255, 42, 149); color: rgb(255, 42, 149);" data-color="255, 42, 149" data-theme="magenta" title="Hot Magenta"></button>
        <button class="color-btn" style="background: rgb(255, 102, 153); color: rgb(255, 102, 153);" data-color="255, 102, 153" data-theme="rosegold" title="Rose Gold"></button>
        <button class="color-btn" style="background: rgb(252, 69, 102); color: rgb(252, 69, 102);" data-color="252, 69, 102" data-theme="red" title="Crimson Red"></button>
        <button class="color-btn" style="background: rgb(255, 87, 34); color: rgb(255, 87, 34);" data-color="255, 87, 34" data-theme="blood" title="Blood Orange"></button>
        <button class="color-btn" style="background: rgb(255, 127, 80); color: rgb(255, 127, 80);" data-color="255, 127, 80" data-theme="coral" title="Sunset Coral"></button>

        <!-- Baris 4: Oranye, Kuning & Netral -->
        <button class="color-btn" style="background: rgb(252, 182, 69); color: rgb(252, 182, 69);" data-color="252, 182, 69" data-theme="orange" title="Warning Orange"></button>
        <button class="color-btn" style="background: rgb(255, 191, 0); color: rgb(255, 191, 0);" data-color="255, 191, 0" data-theme="gold" title="Cyber Gold"></button>
        <button class="color-btn" style="background: rgb(255, 222, 89); color: rgb(255, 222, 89);" data-color="255, 222, 89" data-theme="yellow" title="Electric Yellow"></button>
        <button class="color-btn" style="background: rgb(204, 255, 0); color: rgb(204, 255, 0);" data-color="204, 255, 0" data-theme="lime" title="Radioactive Lime"></button>
        <button class="color-btn" style="background: rgb(224, 224, 224); color: rgb(224, 224, 224);" data-color="224, 224, 224" data-theme="silver" title="Ghost Silver"></button>
      </div>
    </div>
  </div>

  <script>
    // =========================================
    // SCRIPT LOGIKA THEME SWITCHER
    // =========================================
    document.addEventListener('DOMContentLoaded', () => {
      const themeToggleBtn = document.getElementById('theme-toggle');
      const themePanel = document.getElementById('theme-panel');
      const colorBtns = document.querySelectorAll('.color-btn');

      themeToggleBtn.addEventListener('click', () => {
        themePanel.classList.toggle('active');
      });

      document.addEventListener('click', (e) => {
        if (!e.target.closest('.theme-switcher-wrapper')) {
          themePanel.classList.remove('active');
        }
      });

      function applyTheme(rgbValues, themeName) {
        document.documentElement.style.setProperty('--accent-rgb', rgbValues);
        localStorage.setItem('exhub_theme_rgb', rgbValues);
        localStorage.setItem('exhub_theme_name', themeName);

        colorBtns.forEach(btn => {
          if(btn.dataset.theme === themeName) {
            btn.classList.add('active');
          } else {
            btn.classList.remove('active');
          }
        });
      }

      const savedThemeName = localStorage.getItem('exhub_theme_name') || 'green';
      colorBtns.forEach(btn => {
        if (btn.dataset.theme === savedThemeName) {
          btn.classList.add('active');
        } else {
          btn.classList.remove('active');
        }
        
        btn.addEventListener('click', () => {
          applyTheme(btn.dataset.color, btn.dataset.theme);
        });
      });
    });
  </script>
</body>
</html>
