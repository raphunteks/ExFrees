<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title><%= siteName || 'ExHub' %> - Home</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  
  <!-- SCRIPT PENCEGAH FOUC (Flash of Unstyled Content) -->
  <!-- Script ini mengeksekusi tema *sebelum* halaman dirender, agar warna tidak berkedip saat reload -->
  <script>
    (function() {
      const savedRgb = localStorage.getItem('exhub_theme_rgb');
      if (savedRgb) {
        document.documentElement.style.setProperty('--accent-rgb', savedRgb);
      }
    })();
  </script>

  <link rel="stylesheet" href="/public/css/main.css" />
  <link rel="icon" type="image/png" href="/public/img/logo-exhub.png" />
  <script src="/public/js/protect.js" defer></script>
</head>
<body class="page-dark">

  <!-- NAVBAR (reuse partial supaya konsisten di semua halaman) -->
  <%- include('partials/nav', { active: 'home' }) %>

  <main>
    <!-- HERO / LANDING GRID -->
    <section class="hero">
      <!-- LEFT: main copy -->
      <section class="hero-main">
        <h1>
          Let's Hype With<br />
          <span class="accent"><%= siteName %></span>.
        </h1>

        <p class="hero-sub">
          Exclusive Roblox scripts with features tuned for better performance,
          key-protected via Discord and ads provider.
        </p>

        <div class="hero-actions">
          <a href="/get-key?provider=workink" class="btn btn-primary">Get Free Key</a>
          <a href="/scripts" class="btn btn-outline">Browse Scripts</a>
        </div>

        <div class="hero-stats">
          <div class="stat-pill">
            <span class="dot dot-green"></span> Undetected &amp; Secure
          </div>
          <div class="stat-pill">
            <span class="dot dot-green"></span> Multi-Platform Support
          </div>
          <div class="stat-pill">
            <span class="dot dot-green"></span> Instant Updates
          </div>
        </div>

        <div class="hero-loader-card">
          <div class="loader-tabs">
            <button class="tab active">loader.lua</button>
          </div>
          <pre class="code-block">
-- load <%= siteName %> universal loader
loadstring(game:HttpGet("<%= loaderUrl %>"))()
          </pre>
        </div>
      </section>

      <!-- RIGHT: discord + scripts preview -->
      <section class="hero-side">
        <div class="discord-card">
          <!-- Logo Discord SVG yang tajam -->
          <svg class="discord-logo-svg" xmlns="http://www.w3.org/2000/svg" width="50" height="50" viewBox="0 0 127.14 96.36">
            <path fill="#5865F2" d="M107.7,8.07A105.15,105.15,0,0,0,81.47,0a72.06,72.06,0,0,0-3.36,6.83A97.68,97.68,0,0,0,49,6.83,72.37,72.37,0,0,0,45.64,0,105.89,105.89,0,0,0,19.39,8.09C2.79,32.65-1.71,56.6.54,80.21h0A105.73,105.73,0,0,0,32.71,96.36,77.7,77.7,0,0,0,39.6,85.25a68.42,68.42,0,0,1-10.85-5.18c.91-.66,1.8-1.34,2.66-2a75.57,75.57,0,0,0,64.32,0c.87.71,1.76,1.39,2.66,2a68.68,68.68,0,0,1-10.87,5.19,77,77,0,0,0,6.89,11.1A105.25,105.25,0,0,0,126.6,80.22h0C129.24,52.84,122.09,29.11,107.7,8.07ZM42.45,65.69C36.18,65.69,31,60,31,53s5-12.74,11.43-12.74S54,46,53.89,53,48.84,65.69,42.45,65.69Zm42.24,0C78.41,65.69,73.31,60,73.31,53s5-12.74,11.43-12.74S96.3,46,96.19,53,91.08,65.69,84.69,65.69Z"/>
          </svg>
          
          <h2>Join Community</h2>
          <p class="helper-text">
            Connect with other users, get announcements and support.
          </p>

          <!-- Statistik Members (Akan diupdate realtime oleh JS di bawah) -->
          <div class="discord-stats">
            <div class="stat-item">
              <span class="dot dot-online"></span>
              <div class="stat-info">
                <span class="stat-value" id="discord-online">...</span>
                <span class="stat-label">Online</span>
              </div>
            </div>
            <div class="stat-item">
              <span class="dot dot-total"></span>
              <div class="stat-info">
                <span class="stat-value" id="discord-total">...</span>
                <span class="stat-label">Members</span>
              </div>
            </div>
          </div>

          <!-- Link Discord dimasukkan langsung ke href ini -->
          <a
            href="https://discord.gg/Zn3jpF4AdT"
            target="_blank"
            rel="noopener noreferrer"
            class="btn btn-discord btn-full"
          >
            Join Server Discord
          </a>
        </div>

        <div class="scripts-card">
          <h3>Supported Games</h3>
          <p class="scripts-sub">
            A few of the scripts available in <%= siteName %>.
          </p>

          <div class="scripts-list">
            <% (scriptsPreview || []).forEach(function(s) { %>
              <div class="script-item">
                <img
                  src="<%= s.thumbnail || '/public/img/logo-exhub.png' %>"
                  class="script-thumb"
                  alt="<%= s.name %>"
                />
                <div class="script-meta">
                  <div class="script-title-row">
                    <span class="script-name"><%= s.name %></span>
                    <span class="script-version"><%= s.version %></span>
                  </div>

                  <span class="status-pill <%= s.status === 'working' ? 'status-working' : 'status-maint' %>">
                    <%= s.status === 'working' ? 'Working' : 'Maintenance' %>
                  </span>
                </div>
              </div>
            <% }) %>
          </div>

          <a href="/scripts" class="link-muted">View all scripts →</a>
        </div>
      </section>
    </section>
  </main>

  <footer class="footer">
    <span>
      © <%= new Date().getFullYear() %> <%= siteName || 'ExHub' %>.
      Not affiliated with Roblox.
    </span>
  </footer>

  <!-- =========================================
       TOMBOL WIDGET: THEME SWITCHER (20 WARNA)
       ========================================= -->
  <div class="theme-switcher-wrapper">
    <button class="theme-toggle-btn" id="theme-toggle" aria-label="Toggle Theme Panel">
      <!-- Icon Palet / Pengaturan -->
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="3"></circle>
        <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path>
      </svg>
    </button>
    <div class="theme-panel" id="theme-panel">
      <h4>Accent Color</h4>
      <div class="theme-colors">
        <!-- Baris 1: Hijau & Biru Terang -->
        <button class="color-btn active" style="background: rgb(125, 252, 69); color: rgb(125, 252, 69);" data-color="125, 252, 69" data-theme="green" title="Neon Green"></button>
        <button class="color-btn" style="background: rgb(57, 255, 20); color: rgb(57, 255, 20);" data-color="57, 255, 20" data-theme="toxic" title="Toxic Green"></button>
        <button class="color-btn" style="background: rgb(0, 255, 170); color: rgb(0, 255, 170);" data-color="0, 255, 170" data-theme="mint" title="Aqua Mint"></button>
        <button class="color-btn" style="background: rgb(0, 238, 255); color: rgb(0, 238, 255);" data-color="0, 238, 255" data-theme="electric" title="Electric Blue"></button>
        <button class="color-btn" style="background: rgb(69, 182, 252); color: rgb(69, 182, 252);" data-color="69, 182, 252" data-theme="cyan" title="Cyan Blue"></button>

        <!-- Baris 2: Biru, Ungu & Nila -->
        <button class="color-btn" style="background: rgb(153, 221, 255); color: rgb(153, 221, 255);" data-color="153, 221, 255" data-theme="ice" title="Ice Blue"></button>
        <button class="color-btn" style="background: rgb(138, 43, 226); color: rgb(138, 43, 226);" data-color="138, 43, 226" data-theme="violet" title="Deep Violet"></button>
        <button class="color-btn" style="background: rgb(182, 69, 252); color: rgb(182, 69, 252);" data-color="182, 69, 252" data-theme="purple" title="Synthwave Purple"></button>
        <button class="color-btn" style="background: rgb(75, 0, 130); color: rgb(75, 0, 130);" data-color="75, 0, 130" data-theme="indigo" title="Abyssal Indigo"></button>
        <button class="color-btn" style="background: rgb(255, 0, 255); color: rgb(255, 0, 255);" data-color="255, 0, 255" data-theme="plasma" title="Plasma Pink"></button>

        <!-- Baris 3: Merah Muda, Merah & Koral -->
        <button class="color-btn" style="background: rgb(255, 42, 149); color: rgb(255, 42, 149);" data-color="255, 42, 149" data-theme="magenta" title="Hot Magenta"></button>
        <button class="color-btn" style="background: rgb(255, 102, 153); color: rgb(255, 102, 153);" data-color="255, 102, 153" data-theme="rosegold" title="Rose Gold"></button>
        <button class="color-btn" style="background: rgb(252, 69, 102); color: rgb(252, 69, 102);" data-color="252, 69, 102" data-theme="red" title="Crimson Red"></button>
        <button class="color-btn" style="background: rgb(255, 87, 34); color: rgb(255, 87, 34);" data-color="255, 87, 34" data-theme="blood" title="Blood Orange"></button>
        <button class="color-btn" style="background: rgb(255, 127, 80); color: rgb(255, 127, 80);" data-color="255, 127, 80" data-theme="coral" title="Sunset Coral"></button>

        <!-- Baris 4: Oranye, Kuning & Netral -->
        <button class="color-btn" style="background: rgb(252, 182, 69); color: rgb(252, 182, 69);" data-color="252, 182, 69" data-theme="orange" title="Warning Orange"></button>
        <button class="color-btn" style="background: rgb(255, 191, 0); color: rgb(255, 191, 0);" data-color="255, 191, 0" data-theme="gold" title="Cyber Gold"></button>
        <button class="color-btn" style="background: rgb(255, 222, 89); color: rgb(255, 222, 89);" data-color="255, 222, 89" data-theme="yellow" title="Electric Yellow"></button>
        <button class="color-btn" style="background: rgb(204, 255, 0); color: rgb(204, 255, 0);" data-color="204, 255, 0" data-theme="lime" title="Radioactive Lime"></button>
        <button class="color-btn" style="background: rgb(224, 224, 224); color: rgb(224, 224, 224);" data-color="224, 224, 224" data-theme="silver" title="Ghost Silver"></button>
      </div>
    </div>
  </div>

  <!-- SCRIPT UNTUK MENGAMBIL DATA MEMBER DISCORD SECARA REALTIME & THEME SWITCHER -->
  <script>
    document.addEventListener('DOMContentLoaded', async () => {
      /* =========================================
         1. SCRIPT MENGAMBIL DATA DISCORD
         ========================================= */
      // Menggunakan link invite kamu secara langsung
      const inviteUrl = "https://discord.gg/Zn3jpF4AdT";
      
      // Mengekstrak kode invite (dari "discord.gg/Zn3jpF4AdT" diambil "Zn3jpF4AdT")
      const inviteCodeMatch = inviteUrl.match(/(?:discord\.gg\/|discord\.com\/invite\/)([a-zA-Z0-9-]+)/);
      const inviteCode = inviteCodeMatch ? inviteCodeMatch[1] : null;

      const onlineEl = document.getElementById('discord-online');
      const totalEl = document.getElementById('discord-total');

      if (inviteCode) {
        try {
          // Melakukan HTTP Request ke Discord API
          const response = await fetch(`https://discord.com/api/v9/invites/${inviteCode}?with_counts=true`);
          if (response.ok) {
            const data = await response.json();
            
            // Animasi / Set data ke HTML
            if (onlineEl && data.approximate_presence_count !== undefined) {
              onlineEl.innerText = data.approximate_presence_count.toLocaleString();
            }
            if (totalEl && data.approximate_member_count !== undefined) {
              totalEl.innerText = data.approximate_member_count.toLocaleString();
            }
          } else {
            onlineEl.innerText = "N/A";
            totalEl.innerText = "N/A";
          }
        } catch (err) {
          console.error('Gagal mengambil data Discord:', err);
          onlineEl.innerText = "Error";
          totalEl.innerText = "Error";
        }
      } else {
        onlineEl.innerText = "-";
        totalEl.innerText = "-";
      }

      /* =========================================
         2. SCRIPT LOGIKA THEME SWITCHER
         ========================================= */
      const themeToggleBtn = document.getElementById('theme-toggle');
      const themePanel = document.getElementById('theme-panel');
      const colorBtns = document.querySelectorAll('.color-btn');

      // Tampilkan/Sembunyikan panel saat gear diklik
      themeToggleBtn.addEventListener('click', () => {
        themePanel.classList.toggle('active');
      });

      // Tutup panel jika mengeklik area di luar widget
      document.addEventListener('click', (e) => {
        if (!e.target.closest('.theme-switcher-wrapper')) {
          themePanel.classList.remove('active');
        }
      });

      // Fungsi untuk mengaplikasikan warna dan menyimpan ke memori browser (localStorage)
      function applyTheme(rgbValues, themeName) {
        document.documentElement.style.setProperty('--accent-rgb', rgbValues);
        localStorage.setItem('exhub_theme_rgb', rgbValues);
        localStorage.setItem('exhub_theme_name', themeName);

        // Ubah styling tombol yang aktif (lingkaran putih di sekitar pilihan warna)
        colorBtns.forEach(btn => {
          if(btn.dataset.theme === themeName) {
            btn.classList.add('active');
          } else {
            btn.classList.remove('active');
          }
        });
      }

      // Memeriksa dan menandai tombol warna mana yang terakhir dipilih saat web dibuka
      const savedThemeName = localStorage.getItem('exhub_theme_name') || 'green';
      colorBtns.forEach(btn => {
        if (btn.dataset.theme === savedThemeName) {
          btn.classList.add('active');
        } else {
          btn.classList.remove('active');
        }
        
        // Event saat tombol warna diklik
        btn.addEventListener('click', () => {
          applyTheme(btn.dataset.color, btn.dataset.theme);
        });
      });

    });
  </script>
</body>
</html>
